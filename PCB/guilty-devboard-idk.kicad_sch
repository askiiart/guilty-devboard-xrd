	(text "Notes\n\nif VDDH is applied and >VDD, high voltage mode is used\notherwise, connect VDD to VDDH\nhence here it runs in low voltage mode\n\npotential power savings:\n- make voltage divider more efficient?\n- remove voltage divider entirely?\n  - boards using original xiao will need a separate one anyways, and this allows for easier testing of different resistor values to see what works"
		(exclude_from_sim no)
		(at 15.494 158.242 0)
		(effects
			(font
				(size 1.5 1.5)
			)
			(justify left top)
		)
		(uuid "256a7554-d62c-448a-a7e9-caa3f68c8eeb")
	)
	(text "Battery charger"
		(exclude_from_sim no)
		(at 556.26 152.654 0)
		(effects
